# ── Provider AI ───────────────────────────────────────────────────────────────
# Scegli il provider: claude | gemini | openai | ollama
# Default: claude
AI_PROVIDER=claude

# Modello (opzionale — lascia vuoto per usare il default del provider)
#   claude  → claude-sonnet-4-6
#   gemini  → gemini-2.0-flash
#   openai  → gpt-4o-mini
#   ollama  → llama3
# AI_MODEL=

# ── Chiavi API — decommenta e compila quella del provider scelto ──────────────

# Claude (Anthropic) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google Gemini — https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# ── Ollama (locale, nessuna chiave necessaria) ────────────────────────────────
# Decommentare se AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
