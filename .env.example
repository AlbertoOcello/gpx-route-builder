# ── Provider AI ───────────────────────────────────────────────────────────────
# Valori validi: claude | gemini | openai | ollama
AI_PROVIDER=claude

# Modello opzionale: se vuoto usa il default del provider
#   claude  → claude-sonnet-4-6
#   gemini  → gemini-2.0-flash
#   openai  → gpt-4o-mini
#   ollama  → llama3
# AI_MODEL=

# ── Chiavi API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
